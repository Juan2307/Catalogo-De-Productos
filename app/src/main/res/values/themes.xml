<resources>
    <!-- BASE THEME -->
    <style name="Base.Theme.CatalogoDeProductos" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- COLORES -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="android:windowBackground">@color/background</item>

        <!-- TEXTO -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

    </style>

    <!-- THEME PRINCIPAL -->
    <style name="Theme.CatalogoDeProductos" parent="Base.Theme.CatalogoDeProductos" />

    <!--  ================= COMPONENTES ================= -->

    <!--  FILA PERFIL -->
    <style name="ProfileInfoRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@drawable/profile_row_divider</item>
    </style>

    <!-- LABEL PERFIL -->
    <style name="ProfileInfoLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/primary_light</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <!-- VALOR PERFIL -->
    <style name="ProfileInfoValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">end</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
    </style>

    <!-- MENÚ LATERAL -->
    <style name="MenuItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">24dp</item>
    </style>

    <!-- ICONO -->
    <style name="MenuItemIconStyle">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <!-- TEXTO MENÚ -->
    <style name="MenuItemTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <!-- BOTONES PRINCIPALES -->
    <style name="PrimaryButtonText">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- INPUTS -->
    <style name="InputTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

</resources>