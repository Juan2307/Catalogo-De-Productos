<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/footer_photos"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Breadcrumb -->
            <TextView
                android:id="@+id/txt_photos"
                style="@style/MenuItemTextStyle"
                android:visibility="gone"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mod_fotos"
                android:layout_margin="16dp"
                android:fontFamily="@font/nico_moji_regular"
                android:textColor="#666666"
                android:textSize="14sp" />

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="260dp">

                <!-- IMAGEN FONDO -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/fondo_fotos"
                    android:contentDescription="@string/desc_portada_fotos"/>

                <!-- OVERLAY OSCURO -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#55000000"/>

                <TextView
                    style="@style/ProfileInfoLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="40dp"
                    android:fontFamily="@font/nico_moji_regular"
                    android:gravity="center"
                    android:lineSpacingMultiplier="0.7"
                    android:text="@string/frase_portada_fotos"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <!-- Titulo Seccion Productos -->
            <TextView
                style="@style/ProfileInfoLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:lineSpacingMultiplier="0.7"
                android:text="@string/titulo_prod_fotos"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                android:shadowColor="#22004AAD"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4" />

            <!-- Productos -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:paddingHorizontal="8dp"
                android:paddingBottom="16dp">

                <!-- CARD PRODUCTO (1) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- ICONO -->
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="end"
                            android:contentDescription="@string/desc_btn_carrito"
                            android:src="@drawable/shopping_cart"
                            app:tint="@color/primary"/>

                        <!-- IMAGEN -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:layout_marginTop="8dp"
                            app:cardCornerRadius="14dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/desc_producto1_fotos"
                                android:padding="10dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/producto1"
                                tools:ignore="ImageContrastCheck" />
                        </androidx.cardview.widget.CardView>

                        <!-- TITULO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/nom_prod1_fotos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="10dp"/>

                        <!-- SUBTEXTO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_prod1_fotos"
                            android:textSize="12sp"
                            android:textColor="#777777"
                            android:layout_marginTop="2dp"/>

                        <!-- PRECIO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/precio_prod1_fotos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- CARD PRODUCTO (2) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- ICONO -->
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="end"
                            android:contentDescription="@string/desc_btn_carrito"
                            android:src="@drawable/shopping_cart"
                            app:tint="@color/primary"/>

                        <!-- IMAGEN -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:layout_marginTop="8dp"
                            app:cardCornerRadius="14dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="10dp"
                                android:scaleType="fitCenter"
                                android:contentDescription="@string/desc_producto2_fotos"
                                android:src="@drawable/producto2"/>
                        </androidx.cardview.widget.CardView>

                        <!-- TITULO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/nom_prod2_fotos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="10dp"/>

                        <!-- SUBTEXTO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_prod2_fotos"
                            android:textSize="12sp"
                            android:textColor="#777777"
                            android:layout_marginTop="2dp"/>

                        <!-- PRECIO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/precio_prod2_fotos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- CARD PRODUCTO (3) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- ICONO -->
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="end"
                            android:contentDescription="@string/desc_btn_carrito"
                            android:src="@drawable/shopping_cart"
                            app:tint="@color/primary"/>

                        <!-- IMAGEN -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:layout_marginTop="8dp"
                            app:cardCornerRadius="14dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="10dp"
                                android:scaleType="fitCenter"
                                android:contentDescription="@string/desc_producto3_fotos"
                                android:src="@drawable/producto3"/>
                        </androidx.cardview.widget.CardView>

                        <!-- TITULO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/nom_prod3_fotos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="10dp"/>

                        <!-- SUBTEXTO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_prod3_fotos"
                            android:textSize="12sp"
                            android:textColor="#777777"
                            android:layout_marginTop="2dp"/>

                        <!-- PRECIO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/precio_prod3_fotos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- CARD PRODUCTO (4) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- ICONO -->
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="end"
                            android:contentDescription="@string/desc_btn_carrito"
                            android:src="@drawable/shopping_cart"
                            app:tint="@color/primary"/>

                        <!-- IMAGEN -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:layout_marginTop="8dp"
                            app:cardCornerRadius="14dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="10dp"
                                android:scaleType="fitCenter"
                                android:contentDescription="@string/desc_producto4_fotos"
                                android:src="@drawable/producto4"/>
                        </androidx.cardview.widget.CardView>

                        <!-- TITULO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/nom_prod4_fotos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="10dp"/>

                        <!-- SUBTEXTO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_prod4_fotos"
                            android:textSize="12sp"
                            android:textColor="#777777"
                            android:layout_marginTop="2dp"/>

                        <!-- PRECIO -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/precio_prod4_fotos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- CONTACTO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:text="@string/email_subrayado"
                android:textColor="@color/primary"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/footer_photos"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/foot_profile"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:contentDescription="@string/desc_btn_perfil"

            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/perfil"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_video"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:contentDescription="@string/desc_btn_videos"
            android:src="@drawable/video"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_web"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="@string/desc_btn_web"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/web"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_buttons"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:contentDescription="@string/desc_btn_botones"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/buttons"
            app:tint="@color/white" />

    </LinearLayout>

</RelativeLayout>
