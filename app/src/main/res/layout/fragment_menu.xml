<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:orientation="vertical">

    <!-- Sección Botón Hamburguesa Superior -->
    <FrameLayout
        android:id="@+id/btn_toggle_menu"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_menu" />

    </FrameLayout>

    <!-- Divisor sutil -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20FFFFFF"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp" />

    <!-- Items de Navegación -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="10dp">

        <LinearLayout
            android:id="@+id/btn_profile"
            style="@style/MenuItemStyle"
            android:paddingStart="23dp">

            <ImageView
                style="@style/MenuItemIconStyle"
                android:src="@drawable/perfil"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/txt_profile"
                style="@style/MenuItemTextStyle"
                android:text="Perfil"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_photos"
            style="@style/MenuItemStyle"
            android:paddingStart="23dp">

            <ImageView
                style="@style/MenuItemIconStyle"
                android:src="@drawable/photo"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/txt_photos"
                style="@style/MenuItemTextStyle"
                android:text="Fotos"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_video"
            style="@style/MenuItemStyle"
            android:paddingStart="23dp">

            <ImageView
                style="@style/MenuItemIconStyle"
                android:src="@drawable/video"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/txt_video"
                style="@style/MenuItemTextStyle"
                android:text="Video"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_web"
            style="@style/MenuItemStyle"
            android:paddingStart="23dp">

            <ImageView
                style="@style/MenuItemIconStyle"
                android:src="@drawable/web"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/txt_web"
                style="@style/MenuItemTextStyle"
                android:text="Web"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_buttons"
            style="@style/MenuItemStyle"
            android:paddingStart="23dp">

            <ImageView
                style="@style/MenuItemIconStyle"
                android:src="@drawable/buttons"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/txt_buttons"
                style="@style/MenuItemTextStyle"
                android:text="Botones"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Footer Logo -->
    <LinearLayout
        android:id="@+id/footer_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="30dp">

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/logos"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/txt_footer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="SPORT POLI"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:visibility="gone"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/txt_footer_slogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVA TU MEJOR VERSIÓN"
            android:textColor="@color/primary_light"
            android:textSize="8sp"
            android:visibility="gone"
            android:gravity="center"
            android:letterSpacing="0.05" />
    </LinearLayout>

</LinearLayout>
