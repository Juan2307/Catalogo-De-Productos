<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/footer_buttons_layout"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Breadcrumb -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modulo Botones"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:layout_margin="16dp"
                android:fontFamily="@font/nico_moji_regular" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <!-- Botón SUPPORT -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_support"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="SUPPORT"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/primary"
                    app:icon="@drawable/ic_support"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconTint="@color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginBottom="12dp"
                    app:cornerRadius="27dp" />

                <!-- Botón CATALOGO -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_catalogo"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="CATALAGO"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/primary"
                    app:icon="@drawable/ic_catalogo"
                    app:iconGravity="start"
                    app:iconPadding="16dp"
                    app:iconTint="@color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginBottom="16dp"
                    app:cornerRadius="27dp" />

            </LinearLayout>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/fondo_botones" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:padding="32dp"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="40dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gracias por\n visitar Sportpoli.\n Esperame verte\n pronto de nuevo\n para seguir\n impulsando tu\n estilo de vida\n activo."
                    android:textSize="27sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.1"
                    android:fontFamily="sans-serif-black" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:text="@string/email_subrayado"
                android:textColor="@color/primary"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/footer_buttons_layout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/foot_profile"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/perfil"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_photos"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/photo"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_video"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/video"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_web"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/web"
            app:tint="@color/white" />

    </LinearLayout>

</RelativeLayout>
