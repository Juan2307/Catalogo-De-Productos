<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:layout_above="@+id/footer_buttons_layout"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Breadcrumb -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/nico_moji_regular"
                android:text="@string/mod_btn"
                android:textColor="#546E7A"
                android:textSize="14sp" />

            <!-- BOTÓN SUPPORT -->
            <Button
                android:id="@+id/btn_support"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/btn_support"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                android:drawableStart="@drawable/ic_support"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                app:cornerRadius="35dp"
                android:elevation="6dp"
                tools:ignore="VisualLintButtonSize" />

            <!-- BOTÓN CATÁLOGO -->
            <Button
                android:id="@+id/btn_catalogo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/btn_catalogo"

                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                android:drawableStart="@drawable/ic_download"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                app:cornerRadius="35dp"
                android:elevation="6dp"
                tools:ignore="VisualLintButtonSize" />

            <!-- IMAGEN -->
            <ImageView
                android:scaleType="fitCenter"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:paddingBottom="20dp"
                android:contentDescription="@string/desc_img_botones"
                android:src="@drawable/fondo_botones" />

            <!-- BLOQUE AZUL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:padding="15dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_frase"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- EMAIL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="14dp"
                android:text="@string/email_subrayado"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/footer_buttons_layout"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="@color/surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="10dp">

        <ImageButton
            android:id="@+id/foot_profile"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:contentDescription="@string/desc_btn_perfil"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/perfil"
            app:tint="@color/white"
            tools:ignore="DuplicateSpeakableTextCheck" />

        <ImageButton
            android:id="@+id/foot_photos"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="10dp"
            android:contentDescription="@string/desc_btn_perfil"
            android:background="@drawable/footer_icon_bg"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/photo"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_video"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:contentDescription="@string/desc_btn_videos"

            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/video"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_web"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="10dp"
            android:contentDescription="@string/desc_btn_web"

            android:background="@drawable/footer_icon_bg"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/web"
            app:tint="@color/white" />

    </LinearLayout>

</RelativeLayout>