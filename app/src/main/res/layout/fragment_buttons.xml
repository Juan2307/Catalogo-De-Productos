<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/footer_buttons_layout"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <Button
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="🎧 SUPPORT"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/sport_blue"
                android:layout_marginBottom="16dp"
                app:cornerRadius="8dp" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="📥 CATALOGO"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/sport_blue"
                android:layout_marginBottom="24dp"
                app:cornerRadius="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="24dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/portada_fondo" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="30dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gracias por visitar Sportpoli. Esperamos verte pronto de nuevo para seguir impulsando tu estilo de vida activo."
                    android:textSize="18sp"
                    android:textColor="@color/sport_blue"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="24dp"
                    android:lineSpacingExtra="4dp"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="sportpoli@corporative.com"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/sport_blue"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>

    <!-- FOOTER CIRCULAR HD -->
    <LinearLayout
        android:id="@+id/footer_buttons_layout"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/foot_profile"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:src="@drawable/perfil"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_photos"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/photo"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_video"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/video"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_web"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/web"
            app:tint="@color/white" />
    </LinearLayout>

</RelativeLayout>
