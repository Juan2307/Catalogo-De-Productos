<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/footer_buttons_layout"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Breadcrumb -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:fontFamily="@font/nico_moji_regular"
                android:text="@string/mod_perfil"
                android:textColor="#666666"
                android:textSize="14sp" />

            <!-- CABECERA -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="260dp">

                <!-- IMAGEN FONDO -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/fondo_perfil"
                    android:contentDescription="@string/desc_portada_perfil" />

                <!-- OVERLAY OSCURO -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#55000000" />

                <!-- CONTENIDO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp">

                    <!-- FOTO PERFIL -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardBackgroundColor="@color/black"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="6dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="92dp"
                            android:layout_height="92dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="46dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/img_perfil"
                                android:contentDescription="@string/desc_foto_perfil" />
                        </androidx.cardview.widget.CardView>

                    </androidx.cardview.widget.CardView>

                    <!-- NOMBRE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nombre_usuario_perfil"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <!-- FRASE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/frase_usuario_perfil"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="6dp"
                        android:paddingHorizontal="24dp"
                        android:alpha="0.9" />

                </LinearLayout>

            </RelativeLayout>

            <!-- INFORMACIÓN PERSONAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="16dp"
                android:padding="20dp"
                android:background="@drawable/bg_card"
                android:elevation="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/info_personal"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:layout_marginBottom="16dp" />

                <!-- EDAD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/edad"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/edad_numero"
                        android:textColor="#000000"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE" />

                <!-- PESO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/peso"
                        android:textColor="#666666" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/peso_numero"
                        android:textColor="#000000"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE" />

                <!-- ESTATURA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/estatura"
                        android:textColor="#666666" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estatura_numero"
                        android:textColor="#000000"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE" />

                <!-- IMC -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/imc"
                        android:textColor="#666666" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/imc_numero"
                        android:textColor="#2E7D32"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- IMAGEN MOTIVACIONAL RESPONSIVE -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_motivacional"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.8">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/img_motivacional"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/desc_img_motivacional_perfil"
                            android:scaleType="centerCrop"
                            android:src="@drawable/gym" />

                        <!-- Overlay oscuro para que la letra blanca se lea siempre bien -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#40000000" />

                    </FrameLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:elevation="5dp"
                    android:fontFamily="@font/nico_moji_regular"
                    android:gravity="center"
                    android:text="@string/frase_gym_perfil"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    app:layout_constraintBottom_toBottomOf="@id/card_motivacional"
                    app:layout_constraintEnd_toEndOf="@id/card_motivacional"
                    app:layout_constraintStart_toStartOf="@id/card_motivacional"
                    app:layout_constraintTop_toTopOf="@id/card_motivacional"
                    app:layout_constraintWidth_percent="0.6" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- CONTACTO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:text="@string/email_subrayado"
                android:textColor="@color/primary"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/footer_buttons_layout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="@color/surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/foot_photos"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="@string/desc_btn_fotos"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/photo"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_video"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="@string/desc_btn_videos"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/video"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_web"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="@string/desc_btn_web"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/web"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_buttons"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="@string/desc_btn_botones"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/buttons"
            app:tint="@color/white" />

    </LinearLayout>

</RelativeLayout>
