<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/footer_profile"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Breadcrumb -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:fontFamily="@font/nico_moji_regular"
                android:text="Modulo Perfil"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

            <!-- CABECERA -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="250dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/fondo_perfil" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="94dp"
                        android:layout_height="94dp"
                        app:cardBackgroundColor="@color/accent_green"
                        app:cardCornerRadius="47dp"
                        app:cardElevation="4dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="44dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/img_pefil" />
                        </androidx.cardview.widget.CardView>

                    </androidx.cardview.widget.CardView>

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="USER"
                        android:textColor="@color/white" />

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="Ana Lorena Guevara"
                        android:textColor="@color/white"
                        android:textSize="22sp" />

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="180dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:gravity="center"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="TRABAJA DURO Y DEJA QUE EL ÉXITO SEA EL QUE HAGA EL RUIDO"
                        android:textColor="@color/white"
                        android:textSize="9sp" />

                </LinearLayout>

            </RelativeLayout>

            <!-- INFORMACIÓN PERSONAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="24dp"
                android:background="@color/surface_variant"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/ProfileInfoLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nico_moji_regular"
                    android:gravity="center"
                    android:lineSpacingMultiplier="0.7"
                    android:shadowColor="#30004AAD"
                    android:shadowDx="6"
                    android:shadowDy="6"
                    android:shadowRadius="1"
                    android:text="Información Personal"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout style="@style/ProfileInfoRow">

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="Edad"
                        android:textColor="@color/primary" />

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:gravity="end"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="28 Años"
                        android:textColor="@color/black" />

                </LinearLayout>

                <LinearLayout style="@style/ProfileInfoRow">

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="Peso Actual"
                        android:textColor="@color/primary" />

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:gravity="end"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="72 Kg"
                        android:textColor="@color/black" />

                </LinearLayout>

                <LinearLayout style="@style/ProfileInfoRow">

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="Estatura"
                        android:textColor="@color/primary" />

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:gravity="end"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="1.72 m"
                        android:textColor="@color/black" />

                </LinearLayout>

                <LinearLayout
                    style="@style/ProfileInfoRow"
                    android:layout_marginBottom="0dp">

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="Imc"
                        android:textColor="@color/primary" />

                    <TextView
                        style="@style/ProfileInfoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nico_moji_regular"
                        android:gravity="end"
                        android:lineSpacingMultiplier="0.7"
                        android:shadowColor="#30004AAD"
                        android:shadowDx="6"
                        android:shadowDy="6"
                        android:shadowRadius="1"
                        android:text="23.5 - normal"
                        android:textColor="@color/black" />

                </LinearLayout>

            </LinearLayout>

            <!-- IMAGEN MOTIVACIONAL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_marginHorizontal="40dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="2dp"
                app:cardElevation="10dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/content_perfil" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true"
                        android:layout_marginBottom="40dp"
                        android:gravity="center"
                        android:text="ENCUENTRA\nTU LIMITE\nCON\nNOSOTROS"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:shadowColor="@color/primary"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="20"
                        android:lineSpacingExtra="-8dp" />

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:text="@string/email_subrayado"
                android:textColor="@color/primary"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/footer_profile"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/foot_photos"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/photo"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_video"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/video"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_web"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/web"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_buttons"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/buttons"
            app:tint="@color/white" />

    </LinearLayout>

</RelativeLayout>