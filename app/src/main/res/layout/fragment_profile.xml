<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- MENÚ IZQUIERDO (30%) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.3"
        android:orientation="vertical"
        android:background="#5679A6"
        android:paddingTop="40dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Catálogo\nDe Productos"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:id="@+id/btnPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Perfil"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/btnFotos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fotos"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/btnVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Video"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/btnWeb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Web"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/btnBotones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Botones"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textSize="14sp"/>

    </LinearLayout>


    <!--  CONTENIDO DERECHO (70%) -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.7"
        android:background="#F6F7FB">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- PORTADA -->




            <!-- FOTO PERFIL -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:src="@drawable/portada_fondo" />

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginTop="-60dp"
                android:src="@drawable/perfil"
                android:elevation="8dp"
                android:padding="6dp"
                android:scaleType="centerCrop"/>

            <!-- NOMBRE Y DATOS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mateo Guerrero"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mateoguerrero@gmail.com"
                    android:textSize="14sp"
                    android:textColor="#7F8C8D"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+57 323 452 0964"
                    android:textSize="14sp"
                    android:textColor="#7F8C8D"/>
            </LinearLayout>

            <!-- BOTONES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="25dp">

                <Button
                    android:layout_width="125dp"
                    android:layout_height="wrap_content"
                    android:text="Editar Perfil"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#000000"
                    android:layout_marginEnd="10dp"/>

                <Button
                    android:layout_width="125dp"
                    android:layout_height="wrap_content"
                    android:text="Contactar"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#000000"/>
            </LinearLayout>

            <!-- PREFERENCIAS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preferencias"
                android:textSize="18sp"
                android:textColor="#2C3E50"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:id="@+id/layoutPreferencias"
                style="?android:attr/buttonBarStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="20dp"
                android:weightSum="3">

                <Button
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#4A90E2"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Ropa"
                    android:textColor="#FFFFFF" />

                <Button
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#4A90E2"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Calzado"
                    android:textColor="#FFFFFF" />
            </LinearLayout>




            <!-- HISTORIAL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Historial de Compras"
                android:textSize="18sp"
                android:textColor="#2C3E50"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingBottom="8dp"/>

            <!-- PRODUCTOS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="30dp">

                <!-- PRODUCTO 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:radius="16dp"
                    android:elevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:id="@+id/imgProducto1"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:src="@drawable/producto1"
                            android:scaleType="centerCrop"
                            android:background="#ECEFF1"
                            android:clipToOutline="true"
                            android:layout_marginEnd="12dp"
                            android:radius="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtTituloProducto1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tenis Nike"
                                android:textStyle="bold"
                                android:textColor="#34495E"
                                android:textSize="16sp"/>

                            <TextView
                                android:id="@+id/txtDescripcion1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Comodidad y estilo deportivo"
                                android:textColor="#7F8C8D"
                                android:textSize="14sp"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:id="@+id/txtPrecio1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$200.000"
                                android:textColor="#E74C3C"
                                android:textStyle="bold"
                                android:layout_marginTop="6dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- PRODUCTO 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:radius="16dp"
                    android:elevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:id="@+id/imgProducto2"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:src="@drawable/producto2"
                            android:scaleType="centerCrop"
                            android:background="#ECEFF1"
                            android:clipToOutline="true"
                            android:layout_marginEnd="12dp"
                            android:radius="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtTituloProducto2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Camiseta Adidas"
                                android:textStyle="bold"
                                android:textColor="#34495E"
                                android:textSize="16sp"/>

                            <TextView
                                android:id="@+id/txtDescripcion2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tela transpirable"
                                android:textColor="#7F8C8D"
                                android:textSize="14sp"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:id="@+id/txtPrecio2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$80.000"
                                android:textColor="#E74C3C"
                                android:textStyle="bold"
                                android:layout_marginTop="6dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>