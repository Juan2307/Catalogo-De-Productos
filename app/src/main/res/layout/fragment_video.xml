<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/footer_video"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modulo Video"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <!-- Headline Artístico -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="has\nparte\ndel 5%\nque ha\ncambiado\nsu vida"
                android:textColor="@color/sport_blue"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="end"
                android:lineSpacingMultiplier="0.8"
                android:layout_marginBottom="24dp"
                android:shadowColor="#40000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="2" />

            <!-- Video 1: Tenis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:id="@+id/container_tenis"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@color/sport_blue"
                    android:padding="2dp">

                    <VideoView
                        android:id="@+id/video_view_tenis"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <!-- Placeholder / Thumbnail -->
                    <ImageView
                        android:id="@+id/img_placeholder_tenis"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/portada_fondo"
                        android:scaleType="centerCrop" />

                    <!-- Botones de Control Superpuestos (Se activan al dar play) -->
                    <RelativeLayout
                        android:id="@+id/controls_tenis"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="visible">

                        <ImageView
                            android:id="@+id/btn_play_tenis"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_centerInParent="true"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/sport_blue"
                            android:background="@drawable/footer_icon_bg"
                            android:backgroundTint="@color/white"
                            android:padding="15dp" />

                        <ImageButton
                            android:id="@+id/btn_rewind_tenis"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@id/btn_play_tenis"
                            android:layout_marginEnd="20dp"
                            android:src="@android:drawable/ic_media_rew"
                            android:background="@android:color/transparent"
                            app:tint="@color/white"
                            android:visibility="gone" />

                        <ImageButton
                            android:id="@+id/btn_forward_tenis"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/btn_play_tenis"
                            android:layout_marginStart="20dp"
                            android:src="@android:drawable/ic_media_ff"
                            android:background="@android:color/transparent"
                            app:tint="@color/white"
                            android:visibility="gone" />
                    </RelativeLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tenis: salud en cada golpe"
                    android:background="#E0E0E0"
                    android:padding="10dp"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/sport_blue" />
            </LinearLayout>

            <!-- Video 2: Futbol -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:id="@+id/container_futbol"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@color/sport_blue"
                    android:padding="2dp">

                    <VideoView
                        android:id="@+id/video_view_futbol"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/img_placeholder_futbol"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/portada_fondo"
                        android:scaleType="centerCrop" />

                    <RelativeLayout
                        android:id="@+id/controls_futbol"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/btn_play_futbol"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_centerInParent="true"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/sport_blue"
                            android:background="@drawable/footer_icon_bg"
                            android:backgroundTint="@color/white"
                            android:padding="15dp" />

                        <ImageButton
                            android:id="@+id/btn_rewind_futbol"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@id/btn_play_futbol"
                            android:layout_marginEnd="20dp"
                            android:src="@android:drawable/ic_media_rew"
                            android:background="@android:color/transparent"
                            app:tint="@color/white"
                            android:visibility="gone" />

                        <ImageButton
                            android:id="@+id/btn_forward_futbol"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/btn_play_futbol"
                            android:layout_marginStart="20dp"
                            android:src="@android:drawable/ic_media_ff"
                            android:background="@android:color/transparent"
                            app:tint="@color/white"
                            android:visibility="gone" />
                    </RelativeLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fútbol: energía, resistencia y bienestar"
                    android:background="#E0E0E0"
                    android:padding="10dp"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/sport_blue" />
            </LinearLayout>

            <!-- Video 3: Salud -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="30dp">

                <FrameLayout
                    android:id="@+id/container_salud"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@color/sport_blue"
                    android:padding="2dp">

                    <VideoView
                        android:id="@+id/video_view_salud"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/img_placeholder_salud"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/portada_fondo"
                        android:scaleType="centerCrop" />

                    <RelativeLayout
                        android:id="@+id/controls_salud"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/btn_play_salud"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_centerInParent="true"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/sport_blue"
                            android:background="@drawable/footer_icon_bg"
                            android:backgroundTint="@color/white"
                            android:padding="15dp" />

                        <ImageButton
                            android:id="@+id/btn_rewind_salud"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@id/btn_play_salud"
                            android:layout_marginEnd="20dp"
                            android:src="@android:drawable/ic_media_rew"
                            android:background="@android:color/transparent"
                            app:tint="@color/white"
                            android:visibility="gone" />

                        <ImageButton
                            android:id="@+id/btn_forward_salud"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/btn_play_salud"
                            android:layout_marginStart="20dp"
                            android:src="@android:drawable/ic_media_ff"
                            android:background="@android:color/transparent"
                            app:tint="@color/white"
                            android:visibility="gone" />
                    </RelativeLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Activa tu salud explorando"
                    android:background="#E0E0E0"
                    android:padding="10dp"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/sport_blue" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="sportpoli@corporative.com"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/sport_blue"
                android:gravity="center"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </ScrollView>

    <!-- FOOTER CIRCULAR HD -->
    <LinearLayout
        android:id="@+id/footer_video"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/foot_profile"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/perfil"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_photos"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/photo"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_web"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/web"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/foot_buttons"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/footer_icon_bg"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/buttons"
            app:tint="@color/white" />
    </LinearLayout>

</RelativeLayout>
