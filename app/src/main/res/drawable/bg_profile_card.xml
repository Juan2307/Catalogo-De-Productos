<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Color base elegante -->
    <solid android:color="#FFFFFF" />

    <!-- Bordes redondeados -->
    <corners android:radius="20dp" />

    <!-- Borde sutil -->
    <stroke
        android:width="1dp"
        android:color="#EAEAEA" />

    <!-- Padding interno opcional -->
    <padding
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp" />

</shape>